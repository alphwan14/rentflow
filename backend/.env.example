# RentFlow backend (system engine) environment. Copy to .env and fill in.

# --- Supabase (service role: server-only, bypasses RLS) ---
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# --- SMS provider ---
# "africastalking" (default, PRODUCTION) or "console" (dev only — logs instead
# of sending). There is NO silent fallback: if africastalking is selected but
# AT_USERNAME/AT_API_KEY are missing, the app fails to start.
SMS_PROVIDER=africastalking

# --- Africa's Talking (PRODUCTION credentials) ---
AT_USERNAME=YOUR_PRODUCTION_USERNAME
AT_API_KEY=YOUR_PRODUCTION_API_KEY
# Optional alphanumeric sender id. Must be REGISTERED/approved with AT, or AT
# rejects it (InvalidSenderId). Leave blank to use your account default sender.
AT_FROM=

# --- HTTP / CORS ---
# Render sets PORT automatically; 3001 is the local default.
# CORS_ORIGINS: comma-separated frontend origins. Any *.vercel.app preview is
# also allowed automatically. Set this to your production Vercel domain.
CORS_ORIGINS=http://localhost:3000

# --- Worker tuning ---
PORT=3001
SMS_WORKER_INTERVAL_MS=5000
SMS_WORKER_BATCH_SIZE=20
SMS_MAX_ATTEMPTS=6
SMS_VISIBILITY_TIMEOUT_SEC=120

# Optional: protects the manual POST /sms/process trigger (Bearer or X-Worker-Token).
WORKER_ADMIN_TOKEN=

# Optional: protects the POST /sms/delivery-report webhook (?token=...). Set the
# same value in the callback URL you register in the Africa's Talking dashboard.
DELIVERY_REPORT_TOKEN=
