# RentFlow environment — copy to .env.local and fill in from your Supabase project.
# Project Settings -> API in the Supabase dashboard.
# Do NOT put real keys in this file — it is a committed template.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Base URL of the RentFlow backend (NestJS on Render). Optional today.
# local: http://localhost:3001  |  prod: https://YOUR-BACKEND.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:3001

# Server-only. NEVER expose to the client or commit it. Used by background
# workers (e.g. SMS sender) that need to bypass RLS. Not required for the
# frontend to run.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
